FROM n8nio/n8n:latest

USER root
RUN apk update \
    && apk add --no-cache python3 py3-pip \
    && python3 --version \
    && which python3 \
    && (npm uninstall -g pdf-parse || true) \
    && npm install -g pdf-parse@1.1.1 --force \
    && mkdir -p /home/node \
    && chown -R node:node /home/node
USER node
RUN cd /home/node \
    && npm init -y \
    && npm install pdf-parse@1.1.1 --force
USER node
